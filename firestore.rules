rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── DENY ALL BY DEFAULT ───
    // Client SDK (browser) KHÔNG ĐƯỢC truy cập bất cứ gì
    // Backend Admin SDK tự động bypass rules, vẫn hoạt động bình thường
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── FIREBASE AUTH USERS ───
    // Chỉ user đã đăng nhập Firebase Auth mới truy cập data của mình
    match /system_users/{userId}/{subcollection=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ─── MARKET PRICES (Public read-only) ───
    match /marketPrices/{ticker} {
      allow read: if true;
      allow write: if false;
    }

    // ─── SYSTEM COLLECTION (Admin-controlled via backend Admin SDK) ───
    // Public read for prices & config (users need to read market prices)
    // Write is ALWAYS false — only backend Admin SDK can write (bypasses rules)
    match /system/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
